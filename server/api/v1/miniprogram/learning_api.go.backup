// ToggleCollect
// @Tags Learning
// @Summary 切换收藏状态
// @Security ApiKeyAuth
// @accept application/json
// @Produce application/json
// @Param data body request.ToggleCollectRequest true "切换收藏请求"
// @Success 200 {object} response.Response{data=bool,msg=string} "操作成功"
// @Router /learning/collect [post]
func (l *LearningApi) ToggleCollect(c *gin.Context) {
	var req request.ToggleCollectRequest
	err := c.ShouldBindJSON(&req)
	if err != nil {
		response.FailWithMessage(err.Error(), c)
		return
	}

	// 获取当前用户ID
	userID, err := utils.GetClaims(c)
	if err != nil {
		response.FailWithMessage("获取用户信息失败", c)
		return
	}

	isCollected, err := service.ServiceGroupApp.MiniprogramServiceGroup.LearningService.ToggleCollect(userID, req.ContentID)
	if err != nil {
		global.GVA_LOG.Error("切换收藏状态失败!", zap.Error(err))
		response.FailWithMessage("操作失败: "+err.Error(), c)
		return
	}

	message := "已取消收藏"
	if isCollected {
		message = "收藏成功"
	}

	response.OkWithDetailed(gin.H{"isCollected": isCollected}, message, c)
}

// GetRecommendations
// @Tags Learning
// @Summary 获取推荐内容
// @Security ApiKeyAuth
// @accept application/json
// @Produce application/json
// @Param data query request.GetRecommendationsRequest true "推荐请求参数"
// @Success 200 {object} response.Response{data=[]response.LearningRecommendationResponse,msg=string} "获取成功"
// @Router /learning/recommendations [get]
func (l *LearningApi) GetRecommendations(c *gin.Context) {
	var req request.GetRecommendationsRequest
	err := c.ShouldBindQuery(&req)
	if err != nil {
		response.FailWithMessage(err.Error(), c)
		return
	}

	// 设置默认分页参数
	if req.PageSize <= 0 {
		req.PageSize = 10
	}

	// 获取当前用户ID
	userID, err := utils.GetClaims(c)
	if err != nil {
		response.FailWithMessage("获取用户信息失败", c)
		return
	}

	recommendations, err := service.ServiceGroupApp.MiniprogramServiceGroup.LearningService.GetRecommendations(userID, req)
	if err != nil {
		global.GVA_LOG.Error("获取推荐内容失败!", zap.Error(err))
		response.FailWithMessage("获取推荐内容失败: "+err.Error(), c)
		return
	}

	response.OkWithData(recommendations, c)
}

