
/* 引入FontAwesome图标 */
/* 注意：微信小程序不支持外部CSS导入，FontAwesome图标需要通过其他方式引入 */
/* @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css'); */
/* 基础卡片样式 */
.nf-card.data-v-c0c434ff {
  border-radius: 16px;
  overflow: hidden;
  transition: all 0.2s ease;
}
/* 基础卡片类型 */
.nf-card--basic.data-v-c0c434ff {
  background-color: #FFFFFF;
  color: #1F2937;
}
/* 高亮卡片类型 */
.nf-card--highlight.data-v-c0c434ff {
  background-color: #FFFFFF;
  color: #1F2937;
  border: 2px solid #34D399;
}
/* 渐变卡片类型 */
.nf-card--gradient.data-v-c0c434ff {
  background: linear-gradient(135deg, #34D399 0%, #10B981 100%);
  color: white;
}
/* 内边距样式 */
.nf-card--padding-small.data-v-c0c434ff {
  padding: 12px;
}
.nf-card--padding-medium.data-v-c0c434ff {
  padding: 16px;
}
.nf-card--padding-large.data-v-c0c434ff {
  padding: 24px;
}
/* 阴影样式 */
.nf-card--shadow.data-v-c0c434ff {
  box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
}
/* 边框样式 */
.nf-card--border.data-v-c0c434ff {
  border: 1px solid #E5E7EB;
}
/* 卡片头部 */
.nf-card__header.data-v-c0c434ff {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}
.nf-card__icon.data-v-c0c434ff {
  margin-right: 8px;
  font-size: 18px;
}
.nf-card__title.data-v-c0c434ff {
  font-size: 18px;
  font-weight: 600;
  line-height: 1.4;
}
/* 卡片内容 */
.nf-card__content.data-v-c0c434ff {
  font-size: 14px;
  line-height: 1.5;
  color: inherit;
}
/* 卡片底部 */
.nf-card__footer.data-v-c0c434ff {
  margin-top: 16px;
  padding-top: 12px;
  border-top: 1px solid rgba(0, 0, 0, 0.1);
}
/* 渐变卡片的特殊样式 */
.nf-card--gradient .nf-card__footer.data-v-c0c434ff {
  border-top-color: rgba(255, 255, 255, 0.2);
}
/* 图标样式 */
.nf-icon.data-v-c0c434ff {
  font-family: "Font Awesome 6 Free";
  font-weight: 900;
}
/* 悬浮效果 */
.nf-card.data-v-c0c434ff:hover {
  -webkit-transform: translateY(-2px);
          transform: translateY(-2px);
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}
.nf-card--gradient.data-v-c0c434ff:hover {
  box-shadow: 0 10px 15px -3px rgba(52, 211, 153, 0.3), 0 4px 6px -2px rgba(52, 211, 153, 0.1);
}
