}
.save-btn.data-v-8a01fc08 {
  background: white;
  color: #667eea;
}
.save-btn.data-v-8a01fc08:disabled {
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.6);
}
.skip-btn.data-v-8a01fc08 {
  background: transparent;
