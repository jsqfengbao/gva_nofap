:root {
  --primary: #34d399;
  --secondary: #06b6d4;
  --accent: #f59e0b;
  --success: #10b981;
  --danger: #ef4444;
  --warning: #f59e0b;
  --info: #3b82f6;
  --background: #f8fafc;
  --surface: #ffffff;
  --card: #ffffff;
  --text-primary: #1f2937;
  --text-secondary: #6b7280;
  --text-muted: #9ca3af;
  --text-white: #ffffff;
  --border: #e5e7eb;
  --border-light: #f3f4f6;
}
.learning-page {
  min-height: 100vh;
  background: #F8FAFC;
  padding-bottom: 140rpx;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  font-size: 24rpx;
  color: #1F2937;
}
.status-bar .time {
  font-weight: 500;
}
.status-bar .status-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.status-bar .status-icons .signal, .status-bar .status-icons .wifi {
  font-size: 20rpx;
}
.status-bar .status-icons .battery {
  width: 48rpx;
  height: 24rpx;
  border: 2rpx solid #1F2937;
  border-radius: 4rpx;
  position: relative;
}
.status-bar .status-icons .battery .battery-level {
  width: 32rpx;
  height: 12rpx;
  background: #10B981;
  border-radius: 2rpx;
  margin: 4rpx;
}

/* 头部 */
.header {
  background: white;
  padding: 32rpx 48rpx;
  border-bottom: 2rpx solid #F3F4F6;
}
.header .header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.header .header-top .title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1F2937;
}
.header .header-top .search-btn {
  width: 80rpx;
  height: 80rpx;
  background: #F3F4F6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.header .header-top .search-btn .search-icon {
  font-size: 32rpx;
  color: #6B7280;
}
.header .category-tabs {
  white-space: nowrap;
}
.header .category-tabs .tabs-container {
  display: flex;
  gap: 16rpx;
}
.header .category-tabs .tabs-container .tab-item {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  background: #F3F4F6;
  border-radius: 50rpx;
}
.header .category-tabs .tabs-container .tab-item .tab-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #6B7280;
}
.header .category-tabs .tabs-container .tab-item.active {
  background: #34D399;
}
.header .category-tabs .tabs-container .tab-item.active .tab-text {
  color: white;
}

/* 主要内容 */
.main-content {
  padding: 48rpx;
  height: calc(100vh - 300rpx);
}

/* 精品课程 */
.featured-course {
  margin-bottom: 48rpx;
}
.featured-course .course-card {
  background: linear-gradient(135deg, #F3E8FF 0%, #E0E7FF 100%);
  border-radius: 32rpx;
  padding: 48rpx;
  border: 2rpx solid #C4B5FD;
  display: flex;
  gap: 32rpx;
}
.featured-course .course-card .course-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}
.featured-course .course-card .course-info {
  flex: 1;
}
.featured-course .course-card .course-info .course-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #DDD6FE;
  color: #7C3AED;
  font-size: 24rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}
.featured-course .course-card .course-info .course-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 8rpx;
}
.featured-course .course-card .course-info .course-desc {
  display: block;
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 24rpx;
  line-height: 1.5;
}
.featured-course .course-card .course-info .course-btn {
  background: #7C3AED;
  color: white;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  display: inline-block;
}
.featured-course .course-card .course-info .course-btn .btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* 学习进度 */
.learning-progress {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.learning-progress .section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 32rpx;
  display: block;
}
.learning-progress .progress-content .weekly-progress {
  margin-bottom: 32rpx;
}
.learning-progress .progress-content .weekly-progress .progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.learning-progress .progress-content .weekly-progress .progress-header .progress-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
}
.learning-progress .progress-content .weekly-progress .progress-header .progress-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #34D399;
}
.learning-progress .progress-content .weekly-progress .progress-bar {
  width: 100%;
  height: 16rpx;
  background: #E5E7EB;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}
.learning-progress .progress-content .weekly-progress .progress-bar .progress-fill {
  height: 100%;
  background: #34D399;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}
.learning-progress .progress-content .weekly-progress .progress-goal {
  font-size: 24rpx;
  color: #6B7280;
}
.learning-progress .progress-content .stats-grid {
  display: flex;
  justify-content: space-around;
  padding-top: 32rpx;
  border-top: 2rpx solid #F3F4F6;
}
.learning-progress .progress-content .stats-grid .stat-item {
  text-align: center;
}
.learning-progress .progress-content .stats-grid .stat-item .stat-number {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #10B981;
  margin-bottom: 8rpx;
}
.learning-progress .progress-content .stats-grid .stat-item .stat-label {
  font-size: 24rpx;
  color: #6B7280;
}

/* 内容区域 */
.content-sections .content-section {
  margin-bottom: 48rpx;
}
.content-sections .content-section .section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.content-sections .content-section .section-header .section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
}
.content-sections .content-section .section-header .more-btn {
  font-size: 28rpx;
  font-weight: 500;
  color: #34D399;
}

/* 文章列表 */
.article-list .article-item {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  display: flex;
  gap: 32rpx;
}
.article-list .article-item .article-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}
.article-list .article-item .article-info {
  flex: 1;
}
.article-list .article-item .article-info .article-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
}
.article-list .article-item .article-info .article-desc {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
  display: block;
  line-height: 1.5;
}
.article-list .article-item .article-info .article-meta {
  display: flex;
  gap: 32rpx;
}
.article-list .article-item .article-info .article-meta .meta-item {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 视频列表 */
.video-list .video-item {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.video-list .video-item .video-thumbnail {
  position: relative;
  margin-bottom: 24rpx;
}
.video-list .video-item .video-thumbnail .video-image {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
}
.video-list .video-item .video-thumbnail .play-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.video-list .video-item .video-thumbnail .play-overlay .play-button {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.video-list .video-item .video-thumbnail .play-overlay .play-button .play-icon {
  font-size: 32rpx;
  color: #1F2937;
  margin-left: 8rpx;
}
.video-list .video-item .video-thumbnail .video-duration {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.7);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}
.video-list .video-item .video-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
}
.video-list .video-item .video-desc {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
  display: block;
  line-height: 1.5;
}
.video-list .video-item .video-meta {
  display: flex;
  gap: 32rpx;
}
.video-list .video-item .video-meta .meta-item {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 音频列表 */
.audio-list .audio-item {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  gap: 32rpx;
}
.audio-list .audio-item .audio-icon {
  width: 128rpx;
  height: 128rpx;
  background: linear-gradient(135deg, #34D399 0%, #06B6D4 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.audio-list .audio-item .audio-icon .headphones {
  font-size: 40rpx;
}
.audio-list .audio-item .audio-info {
  flex: 1;
}
.audio-list .audio-item .audio-info .audio-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
}
.audio-list .audio-item .audio-info .audio-desc {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
  display: block;
  line-height: 1.5;
}
.audio-list .audio-item .audio-info .audio-meta {
  display: flex;
  gap: 32rpx;
}
.audio-list .audio-item .audio-info .audio-meta .meta-item {
  font-size: 24rpx;
  color: #9CA3AF;
}
.audio-list .audio-item .audio-play-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(52, 211, 153, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.audio-list .audio-item .audio-play-btn .play-icon {
  font-size: 28rpx;
  color: #34D399;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
}
.load-more .load-text {
  color: #9CA3AF;
  font-size: 28rpx;
}

/* 搜索弹窗 */
.search-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}
.search-modal .search-content {
  background: white;
  margin: 100rpx 32rpx;
  border-radius: 32rpx;
  padding: 32rpx;
  max-height: 80vh;
  overflow: hidden;
}
.search-modal .search-content .search-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.search-modal .search-content .search-header .search-input {
  flex: 1;
  height: 80rpx;
  background: #F3F4F6;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: none;
  outline: none;
}
.search-modal .search-content .search-header .search-cancel {
  color: #34D399;
  font-size: 28rpx;
  font-weight: 500;
}
.search-modal .search-content .search-results {
  max-height: 60vh;
  overflow-y: auto;
}
.search-modal .search-content .search-results .search-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}
.search-modal .search-content .search-results .search-item:last-child {
  border-bottom: none;
}
.search-modal .search-content .search-results .search-item .search-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
  display: block;
}
.search-modal .search-content .search-results .search-item .search-desc {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.5;
}
.search-modal .search-content .no-results {
  text-align: center;
  padding: 80rpx 0;
}
.search-modal .search-content .no-results .no-results-text {
  color: #9CA3AF;
  font-size: 28rpx;
}