# 生产环境配置文件
# Production Environment Variables

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nofap_production
DB_USER=nofap_user
DB_PASSWORD=your_secure_password_here
DB_ROOT_PASSWORD=your_root_password_here

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# JWT 配置
JWT_SECRET=your_jwt_secret_key_32_chars_minimum

# AES 加密密钥（32位）
AES_KEY=your_aes_encryption_key_32_chars_here

# 微信小程序配置
WECHAT_APPID=your_wechat_mini_program_appid
WECHAT_APPSECRET=your_wechat_mini_program_secret

# 服务器配置
SERVER_PORT=8888
SERVER_HOST=0.0.0.0

# 邮件配置
EMAIL_HOST=smtp.example.com
EMAIL_FROM=noreply@yourdomain.com
EMAIL_TO=admin@yourdomain.com
EMAIL_SECRET=your_email_password

# 监控配置
GRAFANA_PASSWORD=your_grafana_admin_password

# SSL 证书路径（如果使用自定义证书）
SSL_CERT_PATH=/etc/nginx/ssl
SSL_ADMIN_CERT=admin.yourdomain.com.crt
SSL_ADMIN_KEY=admin.yourdomain.com.key
SSL_API_CERT=api.yourdomain.com.crt
SSL_API_KEY=api.yourdomain.com.key

# 域名配置
ADMIN_DOMAIN=admin.yourdomain.com
API_DOMAIN=api.yourdomain.com

# 备份配置
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# 日志配置
LOG_LEVEL=info
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=30

# 性能配置
MAX_CONNECTIONS=200
WORKER_PROCESSES=auto
WORKER_CONNECTIONS=1024

# 安全配置
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=50
MAX_FAILED_ATTEMPTS=10
LOCKOUT_DURATION=3600

# 文件上传配置
MAX_UPLOAD_SIZE=10M
UPLOAD_PATH=/var/uploads/nofap

# 缓存配置
CACHE_TTL=3600
CACHE_MAX_SIZE=512MB

# 时区配置
TZ=Asia/Shanghai

# 环境标识
ENVIRONMENT=production
APP_NAME=nofap-assistant
APP_VERSION=1.0.0 