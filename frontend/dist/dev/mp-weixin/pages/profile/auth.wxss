
.auth-container.data-v-8a01fc08 {
  min-height: 100vh;
  padding: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}
.header.data-v-8a01fc08 {
  text-align: center;
  margin-bottom: 80rpx;
}
.title.data-v-8a01fc08 {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}
.desc.data-v-8a01fc08 {
  font-size: 28rpx;
  opacity: 0.8;
  line-height: 1.5;
}
.avatar-section.data-v-8a01fc08, .nickname-section.data-v-8a01fc08 {
  margin-bottom: 60rpx;
}
.section-title.data-v-8a01fc08 {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}
.avatar-container.data-v-8a01fc08 {
  display: flex;
  justify-content: center;
}
.avatar-btn.data-v-8a01fc08 {
  width: 160rpx;
  height: 160rpx;
  border: none;
  background: none;
  padding: 0;
  border-radius: 50%;
}
.avatar-image.data-v-8a01fc08 {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}
.avatar-placeholder.data-v-8a01fc08 {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.2);
  border: 4rpx dashed rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.camera-icon.data-v-8a01fc08 {
