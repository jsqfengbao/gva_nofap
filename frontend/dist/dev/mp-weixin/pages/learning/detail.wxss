:root {
  --primary: #34d399;
  --secondary: #06b6d4;
  --accent: #f59e0b;
  --success: #10b981;
  --danger: #ef4444;
  --warning: #f59e0b;
  --info: #3b82f6;
  --background: #f8fafc;
  --surface: #ffffff;
  --card: #ffffff;
  --text-primary: #1f2937;
  --text-secondary: #6b7280;
  --text-muted: #9ca3af;
  --text-white: #ffffff;
  --border: #e5e7eb;
  --border-light: #f3f4f6;
}
.learning-detail {
  min-height: 100vh;
  background: #F8FAFC;
  padding-bottom: 140rpx;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  font-size: 24rpx;
  color: #1F2937;
}
.status-bar .time {
  font-weight: 500;
}
.status-bar .status-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.status-bar .status-icons .battery {
  width: 48rpx;
  height: 24rpx;
  border: 2rpx solid #1F2937;
  border-radius: 4rpx;
  position: relative;
}
.status-bar .status-icons .battery .battery-level {
  width: 32rpx;
  height: 12rpx;
  background: #10B981;
  border-radius: 2rpx;
  margin: 4rpx;
}

/* 头部导航 */
.header {
  background: white;
  padding: 32rpx 48rpx;
  border-bottom: 2rpx solid #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.header .back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.header .back-btn .back-icon {
  font-size: 40rpx;
  color: #1F2937;
}
.header .header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
}
.header .actions {
  display: flex;
  gap: 16rpx;
}
.header .actions .action-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.header .actions .action-btn .action-icon {
  font-size: 32rpx;
  color: #6B7280;
}

/* 主要内容 */
.main-content {
  padding: 48rpx;
  height: calc(100vh - 400rpx);
}

/* 内容头部 */
.content-header {
  margin-bottom: 32rpx;
}
.content-header .category-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}
.content-header .category-badge.category-1 {
  background: #DBEAFE;
  color: #1D4ED8;
}
.content-header .category-badge.category-2 {
  background: #D1FAE5;
  color: #059669;
}
.content-header .category-badge.category-3 {
  background: #FEF3C7;
  color: #D97706;
}
.content-header .category-badge.category-4 {
  background: #FCE7F3;
  color: #BE185D;
}
.content-header .content-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1F2937;
  line-height: 1.3;
  margin-bottom: 24rpx;
}
.content-header .content-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.content-header .content-meta .meta-item {
  font-size: 26rpx;
  color: #6B7280;
}
.content-header .content-summary {
  font-size: 30rpx;
  color: #4B5563;
  line-height: 1.6;
  display: block;
}

/* 视频播放器 */
.video-player {
  margin-bottom: 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
}
.video-player .video-element {
  width: 100%;
  height: 400rpx;
}

/* 音频播放器 */
.audio-player {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.audio-player .audio-controls {
  display: flex;
  gap: 32rpx;
  align-items: center;
}
.audio-player .audio-controls .audio-cover {
  position: relative;
  flex-shrink: 0;
}
.audio-player .audio-controls .audio-cover .cover-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
}
.audio-player .audio-controls .audio-cover .play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%);
          transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.audio-player .audio-controls .audio-cover .play-btn .play-icon {
  font-size: 32rpx;
  color: white;
}
.audio-player .audio-controls .audio-info {
  flex: 1;
}
.audio-player .audio-controls .audio-info .audio-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
  display: block;
}
.audio-player .audio-controls .audio-info .progress-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.audio-player .audio-controls .audio-info .progress-container .time-current,
.audio-player .audio-controls .audio-info .progress-container .time-total {
  font-size: 24rpx;
  color: #6B7280;
  width: 80rpx;
}
.audio-player .audio-controls .audio-info .progress-container .progress-bar {
  flex: 1;
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  position: relative;
}
.audio-player .audio-controls .audio-info .progress-container .progress-bar .progress-fill {
  height: 100%;
  background: #34D399;
  border-radius: 4rpx;
  transition: width 0.1s ease;
}

/* 文章内容 */
.article-content {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.article-content .content-body {
  font-size: 32rpx;
  line-height: 1.8;
  color: #1F2937;
}

/* 文本内容 */
.text-content {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.text-content .section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
  display: block;
}
.text-content .content-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #4B5563;
}

/* 学习进度 */
.learning-progress {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.learning-progress .section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 32rpx;
  display: block;
}
.learning-progress .progress-info .progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.learning-progress .progress-info .progress-header .progress-label {
  font-size: 28rpx;
  color: #1F2937;
}
.learning-progress .progress-info .progress-header .progress-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #34D399;
}
.learning-progress .progress-info .progress-bar {
  width: 100%;
  height: 16rpx;
  background: #E5E7EB;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}
.learning-progress .progress-info .progress-bar .progress-fill {
  height: 100%;
  background: #34D399;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}
.learning-progress .progress-info .progress-details .detail-item {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

/* 互动区域 */
.interaction-section {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.interaction-section .action-buttons {
  display: flex;
  justify-content: space-around;
}
.interaction-section .action-buttons .action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.interaction-section .action-buttons .action-item .action-icon {
  font-size: 48rpx;
}
.interaction-section .action-buttons .action-item .action-icon.liked {
  -webkit-animation: heartbeat 0.6s ease-in-out;
          animation: heartbeat 0.6s ease-in-out;
}
.interaction-section .action-buttons .action-item .action-icon.collected {
  color: #F59E0B;
}
.interaction-section .action-buttons .action-item .action-text {
  font-size: 24rpx;
  color: #6B7280;
}

/* 相关推荐 */
.related-content {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.related-content .section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 32rpx;
  display: block;
}
.related-content .related-list .related-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}
.related-content .related-list .related-item:last-child {
  border-bottom: none;
}
.related-content .related-list .related-item .related-image {
  width: 120rpx;
  height: 90rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}
.related-content .related-list .related-item .related-info {
  flex: 1;
}
.related-content .related-list .related-item .related-info .related-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
}
.related-content .related-list .related-item .related-info .related-meta {
  display: flex;
  gap: 16rpx;
}
.related-content .related-list .related-item .related-info .related-meta .meta-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 32rpx 48rpx;
  border-top: 2rpx solid #F3F4F6;
}
.bottom-actions .progress-action .complete-btn {
  width: 100%;
}
.bottom-actions .completed-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.bottom-actions .completed-action .completed-text {
  font-size: 28rpx;
  color: #10B981;
  font-weight: 500;
}
.bottom-actions .completed-action .restart-btn {
  width: 200rpx;
}

/* 评分弹窗 */
.rating-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.rating-modal .rating-content {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  margin: 0 48rpx;
  text-align: center;
}
.rating-modal .rating-content .rating-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 32rpx;
  display: block;
}
.rating-modal .rating-content .stars {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 48rpx;
}
.rating-modal .rating-content .stars .star {
  font-size: 60rpx;
  color: #E5E7EB;
  transition: color 0.2s ease;
}
.rating-modal .rating-content .stars .star.active {
  color: #F59E0B;
}
.rating-modal .rating-content .rating-actions {
  display: flex;
  gap: 24rpx;
}
.rating-modal .rating-content .rating-actions button {
  flex: 1;
}

/* 动画 */
@-webkit-keyframes heartbeat {
0% {
    -webkit-transform: scale(1);
            transform: scale(1);
}
50% {
    -webkit-transform: scale(1.2);
            transform: scale(1.2);
}
100% {
    -webkit-transform: scale(1);
            transform: scale(1);
}
}
@keyframes heartbeat {
0% {
    -webkit-transform: scale(1);
            transform: scale(1);
}
50% {
    -webkit-transform: scale(1.2);
            transform: scale(1.2);
}
100% {
    -webkit-transform: scale(1);
            transform: scale(1);
}
}