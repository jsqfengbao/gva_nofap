/* Loading Toast */
.loading-toast.data-v-52942290 {
  position: fixed;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%);
          transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.8);
  border-radius: 16rpx;
  padding: 32rpx 48rpx;
  z-index: 2000;
