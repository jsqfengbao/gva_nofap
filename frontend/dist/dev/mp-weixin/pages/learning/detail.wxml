<view class="learning-detail"><view class="status-bar"><text class="time">{{a}}</text><view class="status-icons"><text class="signal">📶</text><text class="wifi">📶</text><view class="battery"><view class="battery-level"></view></view></view></view><view class="header"><view class="back-btn" bindtap="{{b}}"><text class="back-icon">←</text></view><text class="header-title">学习详情</text><view class="actions"><view class="action-btn" bindtap="{{d}}"><text class="action-icon">{{c}}</text></view><view class="action-btn" bindtap="{{e}}"><text class="action-icon">📤</text></view></view></view><scroll-view class="main-content" scroll-y="true"><view class="content-header"><view class="{{['category-badge', g]}}"><text class="badge-text">{{f}}</text></view><text class="content-title">{{h}}</text><view class="content-meta"><text class="meta-item">⏱️ {{i}}分钟</text><text class="meta-item">👁️ {{j}}阅读</text><text class="meta-item">❤️ {{k}}点赞</text><text class="meta-item">📅 {{l}}</text></view><text class="content-summary">{{m}}</text></view><view wx:if="{{n}}" class="video-player"><video src="{{o}}" poster="{{p}}" class="video-element" controls bindplay="{{q}}" bindpause="{{r}}" bindtimeupdate="{{s}}"/></view><view wx:if="{{t}}" class="audio-player"><view class="audio-controls"><view class="audio-cover"><image class="cover-image" src="{{v}}" mode="aspectFill"/><view class="play-btn" bindtap="{{x}}"><text class="play-icon">{{w}}</text></view></view><view class="audio-info"><text class="audio-title">{{y}}</text><view class="progress-container"><text class="time-current">{{z}}</text><view class="progress-bar" bindtap="{{B}}"><view class="progress-fill" style="{{'width:' + A}}"></view></view><text class="time-total">{{C}}</text></view></view></view></view><view wx:if="{{D}}" class="article-content"><rich-text class="content-body" nodes="{{E}}"></rich-text></view><view wx:if="{{F}}" class="text-content"><text class="section-title">内容简介</text><rich-text class="content-text" nodes="{{G}}"></rich-text></view><view wx:if="{{H}}" class="learning-progress"><text class="section-title">学习进度</text><view class="progress-info"><view class="progress-header"><text class="progress-label">完成进度</text><text class="progress-value">{{I}}%</text></view><view class="progress-bar"><view class="progress-fill" style="{{'width:' + J}}"></view></view><view class="progress-details"><text class="detail-item">开始时间: {{K}}</text><text wx:if="{{L}}" class="detail-item"> 完成时间: {{M}}</text><text class="detail-item">学习时长: {{N}}分钟</text></view></view></view><view class="interaction-section"><view class="action-buttons"><view class="action-item" bindtap="{{R}}"><text class="{{['action-icon', P && 'liked']}}">{{O}}</text><text class="action-text">{{Q}}</text></view><view class="action-item" bindtap="{{V}}"><text class="{{['action-icon', T && 'collected']}}">{{S}}</text><text class="action-text">{{U}}</text></view><view class="action-item" bindtap="{{W}}"><text class="action-icon">📤</text><text class="action-text">分享</text></view><view class="action-item" bindtap="{{X}}"><text class="action-icon">⭐</text><text class="action-text">评分</text></view></view></view><view wx:if="{{Y}}" class="related-content"><text class="section-title">相关推荐</text><view class="related-list"><view wx:for="{{Z}}" wx:for-item="item" wx:key="e" class="related-item" bindtap="{{item.f}}"><image class="related-image" src="{{item.a}}" mode="aspectFill"/><view class="related-info"><text class="related-title">{{item.b}}</text><view class="related-meta"><text class="meta-text">{{item.c}}</text><text class="meta-text">{{item.d}}分钟</text></view></view></view></view></view></scroll-view><view class="bottom-actions"><view wx:if="{{aa}}" class="progress-action"><nf-button wx:if="{{ac}}" u-s="{{['d']}}" class="complete-btn" bindclick="{{ab}}" u-i="50e1bb75-0" bind:__l="__l" u-p="{{ac}}"> 标记为已完成 </nf-button></view><view wx:else class="completed-action"><text class="completed-text">✅ 已完成学习</text><nf-button wx:if="{{ae}}" u-s="{{['d']}}" class="restart-btn" bindclick="{{ad}}" u-i="50e1bb75-1" bind:__l="__l" u-p="{{ae}}"> 重新学习 </nf-button></view></view><view wx:if="{{af}}" class="rating-modal" bindtap="{{am}}"><view class="rating-content" catchtap="{{al}}"><text class="rating-title">为内容评分</text><view class="stars"><text wx:for="{{ag}}" wx:for-item="star" wx:key="a" class="{{['star', star.b && 'active']}}" bindtap="{{star.c}}"> ⭐ </text></view><view class="rating-actions"><nf-button wx:if="{{ai}}" u-s="{{['d']}}" bindclick="{{ah}}" u-i="50e1bb75-2" bind:__l="__l" u-p="{{ai}}">取消</nf-button><nf-button wx:if="{{ak}}" u-s="{{['d']}}" bindclick="{{aj}}" u-i="50e1bb75-3" bind:__l="__l" u-p="{{ak}}">确定</nf-button></view></view></view></view>